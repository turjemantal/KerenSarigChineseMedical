# ════════════════════════════════════════════════════════════════════════════
#  HOW TO USE THIS FILE
#  1. Copy this file to .env  →  cp .env.example .env
#  2. Fill in the values for your environment (see sections below)
#  3. Never commit .env to git — it contains secrets
# ════════════════════════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────────────────────────
#
#  DEV   → local development. Real messages ARE sent — same as PROD.
#          Use this to verify the full flow end-to-end locally.
#
#  TEST  → automated tests only. Messaging is SKIPPED (just printed to console).
#          No Twilio or WhatsApp credentials needed.
#
#  PROD  → production. Real messages are sent. Credentials below become
#          required depending on which MESSAGING_PROVIDER you choose.
#
APP_ENV=DEV               # DEV | TEST | PROD

PORT=3001
CLIENT_URL=http://localhost:5173   # in prod: your domain, e.g. https://kerensarig.co.il

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/keren-clinic   # docker: mongodb://mongo:27017/keren-clinic

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change-me
ADMIN_PASSWORD=change-me

# ─── Messaging ───────────────────────────────────────────────────────────────
#
#  Choose your provider:
#    sms       → sends real SMS via Twilio  (fill Section A below)
#    whatsapp  → sends via WhatsApp Cloud API (fill Section B below)
#
#  In TEST mode this value is ignored — nothing is sent regardless.
#
MESSAGING_PROVIDER=sms    # sms | whatsapp

# ── Section A: Twilio SMS ─────────────────────────────────────────────────────
#  Required only when:  APP_ENV=PROD  AND  MESSAGING_PROVIDER=sms
#
#  How to get these:
#    1. Sign up at twilio.com
#    2. Copy the Account SID from the Console Dashboard
#    3. Create an API Key (Account → API keys & tokens → Create API key)
#       and copy its SID (SK...) + Secret — the secret is shown only once!
#    4. Buy a US phone number (Phone Numbers → Buy a Number → SMS)
#
#  Auth uses a scoped API Key pair — revocable per-key from the Twilio console
#  without rotating the whole account. The account Auth Token is NOT used.
#
#  Sender (TWILIO_FROM_NUMBER) can be either:
#    - a purchased Twilio number, e.g. +12025551234
#    - an alphanumeric sender ID, e.g. KerenSarig (max 11 chars, at least one
#      letter, one-way only — recipients can't reply). Supported in Israel.
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=KerenSarig

# ── Section B: WhatsApp Cloud API ────────────────────────────────────────────
#  Required only when:  APP_ENV=PROD  AND  MESSAGING_PROVIDER=whatsapp
#
#  How to get these:
#    1. Create a Meta developer app at developers.facebook.com
#    2. Add the WhatsApp product and complete business verification
#    3. Pre-approve each message template in the Meta Business Manager
#
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANGUAGE=he
WHATSAPP_TEMPLATE_OTP=otp_code
WHATSAPP_TEMPLATE_BOOKING_CONFIRMATION=booking_confirmation
# Optional — "request received" template sent on booking (falls back to booking_confirmation until approved by Meta)
WHATSAPP_TEMPLATE_BOOKING_REQUEST=booking_request
WHATSAPP_TEMPLATE_APPOINTMENT_REMINDER=appointment_reminder

# ─── Production only (docker-compose.prod.yml) ────────────────────────────────
#  Full ECR image URLs that the production stack pulls and runs.
#  Format: <account-id>.dkr.ecr.<region>.amazonaws.com/<repo>:latest
#
ECR_SERVER_IMAGE=
ECR_CLIENT_IMAGE=
