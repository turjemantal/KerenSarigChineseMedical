# ════════════════════════════════════════════════════════════════════════════
#  HOW TO USE THIS FILE
#  1. Copy this file to .env  →  cp .env.example .env
#  2. Fill in the values for your environment (see sections below)
#  3. Never commit .env to git — it contains secrets
# ════════════════════════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────────────────────────
#
#  DEV   → local development. Real messages ARE sent — same as PROD.
#          Use this to verify the full flow end-to-end locally.
#
#  TEST  → automated tests only. Messaging is SKIPPED (just printed to console).
#          No Twilio or WhatsApp credentials needed.
#
#  PROD  → production. Real messages are sent. Credentials below become
#          required depending on which MESSAGING_PROVIDER you choose.
#
APP_ENV=DEV               # DEV | TEST | PROD

PORT=3001
CLIENT_URL=http://localhost:5173   # in prod: your domain, e.g. https://keren-clinic.com

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/keren-clinic   # docker: mongodb://mongo:27017/keren-clinic

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change-me
ADMIN_PASSWORD=change-me

# ─── Messaging ───────────────────────────────────────────────────────────────
#
#  Choose your provider:
#    sms       → sends real SMS via Twilio  (fill Section A below)
#    whatsapp  → sends via WhatsApp Cloud API (fill Section B below)
#
#  In TEST mode this value is ignored — nothing is sent regardless.
#
MESSAGING_PROVIDER=sms    # sms | whatsapp

# ── Section A: Twilio SMS ─────────────────────────────────────────────────────
#  Required only when:  APP_ENV=PROD  AND  MESSAGING_PROVIDER=sms
#
#  How to get these:
#    1. Sign up at twilio.com
#    2. Copy Account SID + Auth Token from the Console Dashboard
#    3. Buy a US phone number (Phone Numbers → Buy a Number → SMS)
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Section B: WhatsApp Cloud API ────────────────────────────────────────────
#  Required only when:  APP_ENV=PROD  AND  MESSAGING_PROVIDER=whatsapp
#
#  How to get these:
#    1. Create a Meta developer app at developers.facebook.com
#    2. Add the WhatsApp product and complete business verification
#    3. Pre-approve each message template in the Meta Business Manager
#
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANGUAGE=he
WHATSAPP_TEMPLATE_OTP=otp_code
WHATSAPP_TEMPLATE_BOOKING_CONFIRMATION=booking_confirmation
WHATSAPP_TEMPLATE_APPOINTMENT_REMINDER=appointment_reminder
