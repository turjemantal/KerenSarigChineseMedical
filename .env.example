# Public URL of the site (EC2 public IP or domain, no trailing slash)
# Examples:
#   http://1.2.3.4
#   https://keren-clinic.com
CLIENT_URL=http://YOUR_EC2_IP_OR_DOMAIN

# Auth secrets — generate strong random values for production
# Run: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret
ADMIN_PASSWORD=change-me-to-a-strong-password

# WhatsApp Business Cloud API (optional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANGUAGE=he
WHATSAPP_TEMPLATE_OTP=otp_code
WHATSAPP_TEMPLATE_BOOKING_CONFIRMATION=booking_confirmation
WHATSAPP_TEMPLATE_APPOINTMENT_REMINDER=appointment_reminder
